{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
    schedule: "before 5am on monday"
  },
  packageRules: [
    {
      matchManagers: ["cargo"],
      matchPackageNames: [
        "opentelemetry",
        "opentelemetry_sdk",
        "opentelemetry-otlp",
        "opentelemetry-semantic-conventions",
        "tracing-opentelemetry"
      ],
      groupName: "opentelemetry"
    }
  ]
}
